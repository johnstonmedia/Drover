# ---------------------------------------------------------------------------
# Drover environment variables
# Copy this file to `.env.local` and fill in values. `.env.local` is gitignored.
#
# NOTE: Everything prefixed NEXT_PUBLIC_ is bundled into the browser and is
# therefore PUBLIC. The Firebase web config is *designed* to be public, so it
# lives here. SECRET keys (Groq) do NOT go here — they go only in Vercel.
# ---------------------------------------------------------------------------

# --- Firebase (public web config — safe to expose) ---
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCNVgOMnyxy1dAnXwZmZZDELUmM1Owrt-E
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=drover-9717a.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=drover-9717a
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=drover-9717a.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=235302504218
NEXT_PUBLIC_FIREBASE_APP_ID=1:235302504218:web:d59ab7dc3ee75787a9cea3
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XLFS3JF79M

# --- EmailJS (public client config — safe to expose) ---
# Create a service + template at https://dashboard.emailjs.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# --- Drover API (the Vercel deployment holding the Groq key) ---
# e.g. https://drover-api.vercel.app   (leave blank to use local /server in dev)
NEXT_PUBLIC_API_BASE_URL=

# --- GitHub Pages sub-path (set automatically in CI; leave blank locally) ---
# NEXT_PUBLIC_BASE_PATH=/drover
