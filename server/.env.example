# Drover API (Vercel) environment variables.
# Set these in the Vercel dashboard → Project → Settings → Environment Variables.
# NEVER commit real values.

# --- Groq (SECRET) ---
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
GROQ_MODEL=

# --- CORS: your GitHub Pages origin ---
# e.g. https://johnstonmedia.github.io
ALLOWED_ORIGIN=

# --- Price sources (only set once you've confirmed you're permitted to use them) ---
MLA_PRICES_URL=
MLA_API_KEY=
AUCTIONSPLUS_PRICES_URL=
AUCTIONSPLUS_API_KEY=
